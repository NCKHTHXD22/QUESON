<%- include('../partials/_head', { title: 'Chi tiết Góp ý', user, activeMenu: 'feedbacks' }) %>

<div class="d-flex align-items-center gap-2 mb-3">
  <a href="/admin/feedbacks" class="btn btn-sm btn-outline-secondary">
    <i class="bi bi-arrow-left"></i> Quay lại
  </a>
  <span class="text-muted" style="font-size:.85rem">/ Chi tiết góp ý</span>
</div>

<!-- Flash -->
<% if (flash.error) { %>
<div class="alert alert-danger alert-dismissible py-2 mb-3">
  <i class="bi bi-exclamation-circle me-1"></i><%= flash.error %>
  <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
</div>
<% } %>
<% if (flash.success) { %>
<div class="alert alert-success alert-dismissible py-2 mb-3">
  <i class="bi bi-check-circle me-1"></i><%= flash.success %>
  <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
</div>
<% } %>

<div class="row g-3">
  <!-- Cột trái: Thông tin -->
  <div class="col-lg-7">
    <!-- Thông tin góp ý -->
    <div class="card border-0 shadow-sm mb-3">
      <div class="card-header bg-white fw-semibold py-2">
        <i class="bi bi-person-circle me-2 text-primary"></i>Thông tin người gửi
      </div>
      <div class="card-body">
        <div class="row g-2 mb-3">
          <div class="col-sm-6">
            <div class="text-muted mb-1" style="font-size:.75rem;font-weight:600;text-transform:uppercase">Họ tên</div>
            <div class="fw-semibold"><%= feedback.displayName || '(Ẩn danh)' %></div>
          </div>
          <div class="col-sm-6">
            <div class="text-muted mb-1" style="font-size:.75rem;font-weight:600;text-transform:uppercase">Liên hệ</div>
            <div><i class="bi bi-telephone me-1 text-primary"></i><%= feedback.contact %></div>
          </div>
          <div class="col-sm-6">
            <div class="text-muted mb-1" style="font-size:.75rem;font-weight:600;text-transform:uppercase">Ngày gửi</div>
            <div>
              <i class="bi bi-calendar me-1 text-secondary"></i>
              <%= new Date(feedback.createdAt).toLocaleString('vi-VN', { timeZone: 'Asia/Ho_Chi_Minh' }) %>
            </div>
          </div>
          <div class="col-sm-6">
            <div class="text-muted mb-1" style="font-size:.75rem;font-weight:600;text-transform:uppercase">Trạng thái</div>
            <% const stCls = { pending:'badge-pending', processing:'badge-processing', done:'badge-done' }[feedback.status]; %>
            <span class="badge rounded-pill <%= stCls %> px-2 py-1" style="font-size:.8rem">
              <%= { pending:'Chờ xử lý', processing:'Đang xử lý', done:'Đã xử lý' }[feedback.status] %>
            </span>
          </div>
        </div>

        <div class="mb-3">
          <div class="text-muted mb-2" style="font-size:.75rem;font-weight:600;text-transform:uppercase">Nội dung góp ý</div>
          <div class="bg-light rounded p-3" style="font-size:.9rem;line-height:1.7;white-space:pre-wrap"><%= feedback.content %></div>
        </div>

        <% if (feedback.imageUrl) { %>
        <div>
          <div class="text-muted mb-2" style="font-size:.75rem;font-weight:600;text-transform:uppercase">Hình ảnh đính kèm</div>
          <a href="<%= feedback.imageUrl %>" target="_blank">
            <img src="<%= feedback.imageUrl %>" alt="Ảnh góp ý"
              class="rounded" style="max-width:100%;max-height:320px;object-fit:cover;border:1px solid #e5e7eb">
          </a>
        </div>
        <% } %>
      </div>
    </div>

    <!-- Phản hồi đã gửi -->
    <% if (feedback.response) { %>
    <div class="card border-0 shadow-sm mb-3" style="border-left:4px solid #10b981!important">
      <div class="card-header bg-white fw-semibold py-2" style="font-size:.875rem">
        <i class="bi bi-chat-check me-2 text-success"></i>Phản hồi đã gửi qua Zalo
      </div>
      <div class="card-body">
        <div class="bg-light rounded p-3 mb-2" style="font-size:.9rem;line-height:1.7;white-space:pre-wrap"><%= feedback.response %></div>
        <div class="text-muted d-flex gap-3" style="font-size:.78rem">
          <% if (feedback.respondedAt) { %>
          <span><i class="bi bi-clock me-1"></i><%= new Date(feedback.respondedAt).toLocaleString('vi-VN', { timeZone: 'Asia/Ho_Chi_Minh' }) %></span>
          <% } %>
          <% if (feedback.respondedBy) { %>
          <span><i class="bi bi-person me-1"></i><%= feedback.respondedBy.fullName %></span>
          <% } %>
        </div>
      </div>
    </div>
    <% } %>

    <!-- Ghi chú nội bộ -->
    <% if (feedback.note) { %>
    <div class="card border-0 shadow-sm mb-3">
      <div class="card-header bg-white fw-semibold py-2" style="font-size:.875rem">
        <i class="bi bi-sticky me-2 text-warning"></i>Ghi chú nội bộ
      </div>
      <div class="card-body">
        <div class="bg-light rounded p-3" style="font-size:.875rem;line-height:1.7;white-space:pre-wrap"><%= feedback.note %></div>
      </div>
    </div>
    <% } %>
  </div>

  <!-- Cột phải: Xử lý -->
  <div class="col-lg-5">
    <!-- Cập nhật trạng thái & ghi chú -->
    <div class="card border-0 shadow-sm mb-3">
      <div class="card-header bg-white fw-semibold py-2" style="font-size:.875rem">
        <i class="bi bi-pencil-square me-2 text-primary"></i>Cập nhật xử lý
      </div>
      <div class="card-body">
        <form method="POST" action="/admin/feedbacks/<%= feedback._id %>?_method=PUT">
          <div class="mb-3">
            <label class="form-label fw-semibold" style="font-size:.82rem">Trạng thái</label>
            <select name="status" class="form-select form-select-sm">
              <option value="pending"    <%= feedback.status==='pending'    ? 'selected':'' %>>⏳ Chờ xử lý</option>
              <option value="processing" <%= feedback.status==='processing' ? 'selected':'' %>>⚙️ Đang xử lý</option>
              <option value="done"       <%= feedback.status==='done'       ? 'selected':'' %>>✅ Đã xử lý</option>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold" style="font-size:.82rem">Ghi chú nội bộ</label>
            <textarea name="note" class="form-control form-control-sm" rows="3"
              placeholder="Ghi chú cho nội bộ (người gửi không thấy)"><%= feedback.note %></textarea>
          </div>
          <button type="submit" class="btn btn-primary btn-sm w-100">
            <i class="bi bi-save me-1"></i>Lưu cập nhật
          </button>
        </form>
      </div>
    </div>

    <!-- Phân công -->
    <div class="card border-0 shadow-sm mb-3">
      <div class="card-header bg-white fw-semibold py-2" style="font-size:.875rem">
        <i class="bi bi-person-check me-2 text-info"></i>Phân công xử lý
      </div>
      <div class="card-body">
        <form method="POST" action="/admin/feedbacks/<%= feedback._id %>/assign">
          <div class="mb-2">
            <select name="assignedTo" class="form-select form-select-sm">
              <option value="">-- Chưa phân công --</option>
              <% admins.forEach(function(a) { %>
              <option value="<%= a._id %>"
                <%= feedback.assignedTo && feedback.assignedTo._id.toString() === a._id.toString() ? 'selected':'' %>>
                <%= a.fullName %> (<%= a.username %>)
              </option>
              <% }); %>
            </select>
          </div>
          <button type="submit" class="btn btn-info btn-sm w-100 text-white">
            <i class="bi bi-person-lines-fill me-1"></i>Cập nhật phân công
          </button>
        </form>
      </div>
    </div>

    <!-- Gửi phản hồi Zalo -->
    <div class="card border-0 shadow-sm mb-3">
      <div class="card-header bg-white fw-semibold py-2" style="font-size:.875rem">
        <i class="bi bi-send me-2 text-success"></i>Phản hồi qua Zalo
      </div>
      <div class="card-body">
        <form method="POST" action="/admin/feedbacks/<%= feedback._id %>/reply">
          <div class="mb-2">
            <textarea name="response" class="form-control form-control-sm" rows="4"
              placeholder="Nhập nội dung phản hồi gửi cho người dân qua Zalo..."
              required><%= feedback.response || '' %></textarea>
          </div>
          <button type="submit" class="btn btn-success btn-sm w-100"
            onclick="return confirm('Xác nhận gửi phản hồi này qua Zalo?')">
            <i class="bi bi-send-fill me-1"></i>Gửi phản hồi qua Zalo
          </button>
        </form>
      </div>
    </div>

    <!-- Xóa (superadmin) -->
    <% if (user && user.role === 'superadmin') { %>
    <div class="card border-0 shadow-sm border-danger">
      <div class="card-body d-flex align-items-center justify-content-between py-2">
        <span class="text-muted" style="font-size:.82rem"><i class="bi bi-exclamation-triangle text-danger me-1"></i>Xóa góp ý này</span>
        <form method="POST" action="/admin/feedbacks/<%= feedback._id %>?_method=DELETE">
          <button type="submit" class="btn btn-sm btn-outline-danger"
            onclick="return confirm('Xác nhận xóa vĩnh viễn góp ý này?')">
            <i class="bi bi-trash me-1"></i>Xóa
          </button>
        </form>
      </div>
    </div>
    <% } %>
  </div>
</div>

<%- include('../partials/_footer') %>
