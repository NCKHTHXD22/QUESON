<%- include('../partials/_head', { title: editUser ? 'Sửa tài khoản' : 'Thêm tài khoản', user, activeMenu: 'users' }) %>

<div class="d-flex align-items-center gap-2 mb-3">
  <a href="/admin/users" class="btn btn-sm btn-outline-secondary">
    <i class="bi bi-arrow-left"></i> Quay lại
  </a>
  <span class="text-muted" style="font-size:.85rem">/ <%= editUser ? 'Chỉnh sửa' : 'Thêm mới' %></span>
</div>

<!-- Flash -->
<% if (flash.error) { %>
<div class="alert alert-danger alert-dismissible py-2 mb-3">
  <i class="bi bi-exclamation-circle me-1"></i><%= flash.error %>
  <button type="button" class="btn-close btn-sm" data-bs-dismiss="alert"></button>
</div>
<% } %>

<div class="row justify-content-center">
  <div class="col-lg-6">
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white fw-semibold py-2">
        <i class="bi bi-person-gear me-2 text-primary"></i>
        <%= editUser ? 'Chỉnh sửa tài khoản: @' + editUser.username : 'Tạo tài khoản mới' %>
      </div>
      <div class="card-body">
        <% const formAction = editUser
          ? '/admin/users/' + editUser._id + '?_method=PUT'
          : '/admin/users'; %>
        <form method="POST" action="<%= formAction %>">
          <% if (!editUser) { %>
          <div class="mb-3">
            <label class="form-label fw-semibold" style="font-size:.85rem">
              Tên đăng nhập <span class="text-danger">*</span>
            </label>
            <input type="text" name="username" class="form-control"
              placeholder="Ví dụ: nguyenvan" required autocomplete="off">
            <div class="form-text">Chỉ dùng chữ thường, số, không dấu</div>
          </div>
          <% } %>

          <div class="mb-3">
            <label class="form-label fw-semibold" style="font-size:.85rem">
              Họ và tên <span class="text-danger">*</span>
            </label>
            <input type="text" name="fullName" class="form-control"
              value="<%= editUser ? editUser.fullName : '' %>"
              placeholder="Ví dụ: Nguyễn Văn A" required>
          </div>

          <div class="mb-3">
            <label class="form-label fw-semibold" style="font-size:.85rem">Vai trò</label>
            <select name="role" class="form-select">
              <option value="staff"      <%= !editUser || editUser.role === 'staff'      ? 'selected':'' %>>Nhân viên</option>
              <option value="superadmin" <%= editUser && editUser.role === 'superadmin'  ? 'selected':'' %>>Quản trị viên</option>
            </select>
          </div>

          <div class="mb-4">
            <label class="form-label fw-semibold" style="font-size:.85rem">
              Mật khẩu <% if (!editUser) { %><span class="text-danger">*</span><% } %>
            </label>
            <div class="input-group">
              <input type="password" name="password" id="pwdInput" class="form-control border-end-0"
                placeholder="<%= editUser ? 'Để trống nếu không đổi mật khẩu' : 'Nhập mật khẩu' %>"
                <%= editUser ? '' : 'required' %> autocomplete="new-password">
              <button type="button" class="input-group-text bg-light"
                onclick="togglePwd()" title="Hiện/ẩn">
                <i class="bi bi-eye" id="eyeIcon"></i>
              </button>
            </div>
            <% if (editUser) { %>
            <div class="form-text">Để trống nếu không muốn thay đổi mật khẩu</div>
            <% } %>
          </div>

          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary flex-fill">
              <i class="bi bi-<%= editUser ? 'save' : 'person-plus' %> me-1"></i>
              <%= editUser ? 'Lưu thay đổi' : 'Tạo tài khoản' %>
            </button>
            <a href="/admin/users" class="btn btn-outline-secondary">Hủy</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/_footer') %>
<script>
  function togglePwd() {
    const input = document.getElementById('pwdInput');
    const icon  = document.getElementById('eyeIcon');
    if (input.type === 'password') { input.type = 'text';     icon.className = 'bi bi-eye-slash'; }
    else                           { input.type = 'password'; icon.className = 'bi bi-eye'; }
  }
</script>
